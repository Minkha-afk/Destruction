# Frontend (Next.js) — set these as Environment Variables in Vercel.
# All are PUBLIC (NEXT_PUBLIC_*): they are baked into the client bundle, so they
# must be the *public* URLs of your deployed backend services.

# auth-service
NEXT_PUBLIC_API_URL=https://your-auth-service.onrender.com
# course/learning-service
NEXT_PUBLIC_COURSE_SERVICE_URL=https://your-course-service.onrender.com
# catalog/search-service (both vars point to the same service)
NEXT_PUBLIC_CATALOG_SERVICE_URL=https://your-search-service.onrender.com
NEXT_PUBLIC_SEARCH_SERVICE_URL=https://your-search-service.onrender.com
# chat-service
NEXT_PUBLIC_CHAT_SERVICE_URL=https://your-chat-service.onrender.com



