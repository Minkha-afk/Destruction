# course-service (learning) environment
# On most PaaS PORT is injected automatically — leave it unset there.
PORT=6100

# MongoDB Atlas connection string (same cluster for every service)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/elevana?retryWrites=true&w=majority

# MUST be identical across all services
JWT_SECRET=replace-with-a-long-random-secret

# Comma-separated allowed browser origins (your Vercel URL). Use * only for local dev.
CORS_ORIGIN=https://your-frontend.vercel.app

# Public URL of the deployed catalog (search) service — used to hydrate course content
CATALOG_SERVICE_URL=https://your-search-service.onrender.com

# Shared secret for internal catalog endpoints. MUST match search-service.
INTERNAL_API_SECRET=replace-with-a-shared-internal-secret
